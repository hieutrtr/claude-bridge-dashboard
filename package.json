{
  "name": "@claude-bridge/dashboard",
  "version": "0.1.0",
  "description": "Web dashboard for claude-bridge — observe agents, tasks, loops, and schedules.",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "bun run scripts/start.ts",
    "start:tunnel": "bun run scripts/start.ts --tunnel",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/lib tests/app tests/server",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "lighthouse:mobile": "bun run scripts/lighthouse-mobile.ts",
    "db:introspect": "bun run scripts/introspect.ts"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "drizzle-orm": "^0.40.0",
    "i18next": "^26.0.9",
    "next": "^15.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.14.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "chrome-launcher": "^1.2.1",
    "drizzle-kit": "^0.30.0",
    "lighthouse": "^13.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT"
}
