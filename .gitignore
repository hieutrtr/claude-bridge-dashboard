# Dependencies
node_modules/

# Next.js / TS build output
.next/
out/
dist/
tsconfig.tsbuildinfo

# Auto-generated by Next.js
next-env.d.ts

# Logs
*.log

# Local env (never commit)
.env
.env.local
.env.*.local
*.local

# OS
.DS_Store

# Drizzle introspect temp DB (created by scripts/introspect.ts)
.tmp-introspect.db
.tmp-introspect.db-wal
.tmp-introspect.db-shm

# Playwright (T13) — fixture lives under os.tmpdir(), but artifacts
# from failed runs land here. Anchor to the repo root so the
# Phase-4 phase-test artefact directory at
# `docs/tasks/phase-4/test-results/` (which we *do* want tracked)
# is not swept up by the same name.
/playwright-report/
/test-results/
