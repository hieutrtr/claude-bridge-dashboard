# @claude-bridge/dashboard — Docker Compose env template.
# Copy to docker/.env (gitignored), fill in secrets, then:
#   docker compose -f docker/docker-compose.yml --env-file docker/.env up -d

# ---- Required ----------------------------------------------------

# Owner password used by the legacy P1 password-form login. Even if
# you only invite users via magic-link, this is the break-glass entry
# path — make it strong.
DASHBOARD_PASSWORD=replace-with-≥16-char-random-passphrase

# HS256 signing secret for session JWTs. Rotating this invalidates
# every existing session. Generate with `openssl rand -hex 32`.
JWT_SECRET=replace-with-openssl-rand-hex-32

# ---- Recommended -------------------------------------------------

# Resend HTTP API credentials — needed for magic-link login and the
# T06 email digest. Without these, only DASHBOARD_PASSWORD works.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email of the owner-env user (created on first password login).
OWNER_EMAIL=owner@local

# Salt for IP hashes inside audit_log. Falls back to JWT_SECRET if
# unset; setting it explicitly lets you rotate the JWT without losing
# audit-log IP correlation.
AUDIT_IP_HASH_SALT=

# CSRF Origin allow-list. Add your tunnel hostname here when running
# behind cloudflared (e.g. https://abc-123.trycloudflare.com).
BRIDGE_DASHBOARD_ORIGIN=http://127.0.0.1:7878

# Default UI locale (en | vi).
BRIDGE_LOCALE_DEFAULT=en

# ---- Optional ----------------------------------------------------

# Tag for the local image build. Defaults to "latest"; bump to e.g.
# v0.1.0 when you cut a release.
DASHBOARD_IMAGE_TAG=latest

# Host port the dashboard listens on (loopback bind).
DASHBOARD_HOST_PORT=7878

# Override the daemon-state mount paths if you don't keep them at
# the default ~/.claude-bridge/* location.
BRIDGE_HOST_CONFIG=~/.claude-bridge/config.json
BRIDGE_HOST_DB=~/.claude-bridge/bridge.db
